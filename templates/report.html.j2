<!DOCTYPE html>
<html data-bs-theme="dark">
<head>
<meta charset="utf-8">
<title>TLS Report</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
.badge-red { background-color: #dc3545; }
.badge-yellow { background-color: #ffc107; color: black; }
.badge-green { background-color: #28a745; }
.table-red tr { background-color: #4a0000 !important; }
.table-yellow tr { background-color: #4a3f00 !important; }
.table-green tr { background-color: #003f00 !important; }
</style>

</head>
<body class="bg-dark text-light">

<div class="container mt-4">

<h1 class="mb-4">TLS Scan Report</h1>

<h2>Host Übersicht</h2>
<table class="table table-dark table-striped">
<tr><th>Host</th><th>Status</th></tr>
{% for host, status in overview %}
<tr>
<td>{{ host }}</td>
<td>
    {% if status == 'red' %}
        <span class="badge badge-red">ROT</span>
    {% elif status == 'yellow' %}
        <span class="badge badge-yellow">GELB</span>
    {% else %}
        <span class="badge badge-green">GRÜN</span>
    {% endif %}
</td>
</tr>
{% endfor %}
</table>

<hr>

<h2 class="mt-4">Details nach Ampelstatus</h2>

{% for color, title in [('red','ROT'),('yellow','GELB'),('green','GRÜN')] %}
<h3 class="mt-4">{{ title }}</h3>

{% for host, df in details.items() %}
{% set subset = df[df['ampel'] == color] %}
{% if subset.shape[0] > 0 %}
<h4 class="mt-3">{{ host }}</h4>
<table class="table table-dark table-bordered table-sm table-{{ color }}">
<tr>
{% for col in subset.columns %}
<th>{{ col }}</th>
{% endfor %}
</tr>

{% for _, row in subset.iterrows() %}
<tr>
{% for col in subset.columns %}
<td>{{ row[col] }}</td>
{% endfor %}
</tr>
{% endfor %}
</table>
{% endif %}
{% endfor %}

{% endfor %}

</div>

</body>
</html>
